<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>STUDIO69</title>
    <style>
        :root { --bg: #050505; --panel: rgba(15, 15, 15, 0.95); --border: #333; --neon: #00ffff; --active-bg: rgba(0, 255, 255, 0.1); }
        * { margin: 0; padding: 0; box-sizing: border-box; user-select: none; -webkit-user-select: none; touch-action: none; font-family: monospace; }
        body { background: var(--bg); height: 100vh; width: 100vw; overflow: hidden; color: #666; }
        #viewport { position: absolute; top: 0; left: 0; width: 100%; height: 100%; transform-origin: 0 0; }
        canvas { position: absolute; top: 0; left: 0; display: block; }
        #temp-canvas { z-index: 20; }
        .dock {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); width: 96%; max-width: 500px;
            display: flex; justify-content: space-between; background: var(--panel); padding: 10px;
            border-radius: 40px; border: 1px solid var(--border); z-index: 9999;
        }
        .dock-btn {
            flex: 1; height: 50px; margin: 0 4px; border-radius: 25px; border: 1px solid var(--border);
            background: #111; display: flex; align-items: center; justify-content: center;
            color: #888; font-size: 11px; font-weight: 900; transition: 0.2s; cursor: pointer;
        }
        .active-btn { border-color: var(--neon) !important; color: var(--neon) !important; background: var(--active-bg); box-shadow: 0 0 15px rgba(0, 255, 255, 0.2); }
        .overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); z-index: 9000; display: none;
            align-items: center; justify-content: center; flex-direction: column;
        }
        .menu-box {
            background: var(--panel); border: 1px solid var(--border); padding: 20px;
            border-radius: 20px; width: 90%; max-width: 400px; display: flex; flex-direction: column; gap: 10px;
        }
        .menu-row { display: flex; gap: 10px; width: 100%; }
        .menu-item {
            flex: 1; height: 50px; background: #111; border: 1px solid var(--border); border-radius: 12px;
            display: flex; align-items: center; justify-content: center; color: #aaa; cursor: pointer; font-weight: bold;
        }
        .grid-3x4 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; }
        input[type="range"] { width: 100%; margin: 10px 0; height: 20px; border-radius: 10px; -webkit-appearance: none; outline: none; background: #222; }
        input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; width: 24px; height: 24px; border-radius: 50%; background: #fff; border: 2px solid #000; cursor: pointer; }
        input[type="text"], select { width: 100%; height: 40px; background: #111; color: #fff; border: 1px solid #444; padding: 10px; margin-bottom: 15px; }
        .hidden-file { display: none; }
    </style>
</head>
<body>
    <div id="viewport">
        <canvas id="main-canvas"></canvas>
        <canvas id="temp-canvas"></canvas>
    </div>
    <div class="dock">
        <div class="dock-btn" id="btn-menu" onclick="toggleOverlay('menu')">MENU</div>
        <div class="dock-btn" id="btn-tools" onclick="toggleOverlay('tools')">TOOLS</div>
        <div class="dock-btn" id="btn-color" onclick="toggleOverlay('color')">COLOR</div>
        <div class="dock-btn" onclick="triggerQSave()">QSAVE</div>
    </div>
    <div class="overlay" id="overlay-menu">
        <div class="menu-box">
            <div class="menu-row">
                <div class="menu-item" onclick="document.getElementById('load-file').click()">LOAD PIC</div>
                <div class="menu-item" onclick="document.getElementById('import-file').click()">IMPORT</div>
            </div>
            <div class="menu-item" onclick="triggerSave()">EXPORT SAVE</div>
            <div class="menu-item" onclick="toggleOverlay('vault')">VAULTS</div>
        </div>
    </div>
    <div class="overlay" id="overlay-tools">
        <div class="menu-box">
            <div class="grid-3x4">
                <div class="menu-item tool-btn" onclick="selectTool(this, 'PAINTBRUSH')">BRUSH</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'ERASER')">ERASER</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'PICKER')">PICKER</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'FILL')">FILL</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'CUT')">CUT</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'COPY')">COPY</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'PASTE')">PASTE</div>
                <div class="menu-item tool-btn" onclick="selectTool(this, 'SMOOTH')">SMOOTH</div>
                <div class="menu-item tool-btn" onclick="openTextMenu()">TEXT</div>
                <div class="menu-item tool-btn" onclick="performUndo()">UNDO</div>
                <div class="menu-item tool-btn" onclick="triggerAI()" style="color:#f0f;">AI</div>
            </div>
        </div>
    </div>
    <div class="overlay" id="overlay-color">
        <div class="menu-box" style="align-items: center;">
            <canvas id="brush-preview" width="100" height="100" style="border-radius: 50%; border: 2px solid #fff; margin-bottom: 10px;"></canvas>
            <div style="width: 100%; text-align: left; color: #888; font-size: 10px; margin-top:10px;">MASTER RAINBOW</div>
            <input type="range" id="slider-hue" min="0" max="360" value="180" style="background: linear-gradient(to right, #f00, #ff0, #0f0, #0ff, #00f, #f0f, #f00);">
            <div style="width: 100%; text-align: left; color: #888; font-size: 10px;">SHADES (DARK TO LIGHT)</div>
            <input type="range" id="slider-light" min="0" max="100" value="50">
            <div style="width: 100%; text-align: left; color: #888; font-size: 10px;">BRUSH SIZE</div>
            <input type="range" id="slider-size" min="1" max="100" value="20">
        </div>
    </div>
    <div class="overlay" id="overlay-vault">
        <div class="menu-box">
            <div class="menu-row">
                <div class="menu-item" style="flex-direction:column; padding:10px; height:120px;" onclick="loadVault(0)">
                    <img id="vault-img-0" src="" style="width:100%; height:70px; object-fit:contain; background:#000;">
                    <span style="font-size:10px; margin-top:5px;">LOAD QSAVE 1</span>
                </div>
                <div class="menu-item" style="flex-direction:column; padding:10px; height:120px;" onclick="loadVault(1)">
                    <img id="vault-img-1" src="" style="width:100%; height:70px; object-fit:contain; background:#000;">
                    <span style="font-size:10px; margin-top:5px;">LOAD QSAVE 2</span>
                </div>
            </div>
        </div>
    </div>
    <div class="overlay" id="ui-text" style="z-index:9999;">
        <div class="menu-box">
            <input type="text" id="text-input" placeholder="Type here...">
            <div style="color:#888; font-size:10px;">FONT STYLE</div>
            <select id="text-font">
                <option value="monospace">Typewriter</option>
                <option value="cursive">Cursive / Script</option>
                <option value="sans-serif">Clean Bold</option>
            </select>
            <div style="color:#888; font-size:10px;">ROTATION</div>
            <input type="range" id="text-rotate" min="0" max="360" value="0" oninput="drawTextPreview()">
            <div class="menu-row">
                <div class="menu-item" onclick="startTextSticker()" style="color:#0ff;">PLACE</div>
                <div class="menu-item" onclick="cancelTextSticker()">CANCEL</div>
            </div>
        </div>
    </div>
    <div id="ui-text-confirm" style="display:none; position:fixed; bottom:100px; left:50%; transform:translateX(-50%); z-index:9999; display:flex; gap:10px;">
        <div class="dock-btn" onclick="textObj.fX *= -1; drawTextPreview();" style="width:50px;">FLIP</div>
        <div class="dock-btn" onclick="confirmTextSticker()" style="width:150px; background:#00ffff; color:#000; font-weight:bold;">STAMP</div>
    </div>
    <input type="file" id="load-file" class="hidden-file" accept="image/*">
    <input type="file" id="import-file" class="hidden-file" accept="image/*">
</body>
